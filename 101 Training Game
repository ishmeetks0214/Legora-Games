// ---------- View routing ----------
const VIEWS = ["welcome", "track", "setup", "s1", "s2", "s3-gate", "s3", "results"];
function go(name, opts) {
  opts = opts || {};
  if (!opts.silent && state.view && state.view !== name) {
    state.history.push(state.view);
  }
  state.view = name;
  VIEWS.forEach(v => {
    const el = document.getElementById("view-" + v);
    if (el) el.classList.toggle("hide", v !== name);
  });
  updateProgress();
  window.scrollTo({ top: 0, behavior: "smooth" });
}
function back() {
  if (!state.history.length) return;
  const prev = state.history.pop();
  // Don't re-push the current view onto history when going back.
  go(prev, { silent: true });
}
function updateProgress() {
  const map = { welcome: -1, track: -1, setup: -1, s1: 0, s2: 1, "s3-gate": 2, s3: 2, results: 3 };
  const idx = map[state.view] ?? -1;
  const pips = document.querySelectorAll("#prog .pip");
  pips.forEach((p, i) => {
    p.classList.remove("active", "done");
    if (i < idx) p.classList.add("done");
    if (i === idx) p.classList.add("active");
  });
}

// ---------- Begin (validate name + email) ----------
function beginGame() {
  const nameEl  = document.getElementById("player-name");
  const emailEl = document.getElementById("player-email");
  const err     = document.getElementById("form-error");
  const name  = nameEl.value.trim();
  const email = emailEl.value.trim();
  // Email is optional. Only validate if the user filled it in.
  const emailOk = email === "" || /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email);

  nameEl.classList.toggle("invalid", !name);
  emailEl.classList.toggle("invalid", !emailOk);

  if (!name || !emailOk) {
    err.classList.add("show");
    return;
  }
  err.classList.remove("show");
  state.player.name = name;
  state.player.email = email;
  go("track");
}

// ---------- Track pick ----------
function pickTrack(t) {
  state.track = t;
  loadStage1(); loadStage2(); loadStage3(); loadGate(); loadSetup();
  go("setup");
}

// ---------- Setup view ----------
function loadSetup() {
  const isTx = state.track === "tx";
  const zipName = isTx ? "101-Transactions.zip" : "101-Contentious.zip";
  document.getElementById("setup-download-name").textContent = zipName;
  document.getElementById("setup-download-meta").textContent =
    isTx ? "33 documents · ~1.2 MB" : "33 documents · ~1.1 MB";
  document.getElementById("setup-project-name").textContent =
    isTx ? "Crumbleberry / FlourPower" : "Pondercat v Wormwood";
  // Point the download anchor at the relative zip path. Distributed alongside the HTML.
  const a = document.getElementById("setup-download");
  if (a) { a.setAttribute("href", zipName); a.setAttribute("download", zipName); }
}

