}

function showResults() {
  const max = state.attempted.s3 ? 3 : 2;
  const got = state.scores.s1 + state.scores.s2 + (state.attempted.s3 ? state.scores.s3 : 0);
  document.getElementById("r-score").textContent = (Math.round(got * 2) / 2).toString();
  document.getElementById("r-max").textContent = max;

  let tier = "", comment = "";
  const pct = got / max;
  const first = (state.player.name || "").split(/\s+/)[0] || "";
  if (pct >= 0.95) {
    tier = "Honour roll";
    comment = (first ? `${first}, ` : "") + "if your trainer asks how the 101 went, just say \"watch this\".";
  } else if (pct >= 0.75) {
    tier = "Comfortably competent";
    comment = (first ? `${first} — ` : "") + "you can reach for Legora on a real matter tomorrow and look like you know what you're doing.";
  } else if (pct >= 0.5) {
    tier = "Got the shape";
    comment = (first ? `${first}, ` : "") + "you've got the muscle memory. A second pass on the bits you skimmed will lock it in.";
  } else {
    tier = "Worth a re-run";
    comment = (first ? `No shame in a second go, ${first}.` : "No shame in doing it twice.") + " The platform clicks the second time round.";
  }
  document.getElementById("r-tier").textContent = tier;
  document.getElementById("r-comment").textContent = comment;

  const badges = [
    { id: "s1", name: "Prompt whisperer", got: state.scores.s1 >= 1 },
    { id: "s2", name: "Search detective", got: state.scores.s2 >= 1 },
    { id: "s3", name: "Tabular tamer",    got: state.attempted.s3 && state.scores.s3 >= 1 },
  ];
  const row = document.getElementById("r-badges");
  row.innerHTML = "";
  badges.forEach(b => {
    const el = document.createElement("span");
    el.className = "achievement" + (b.got ? "" : " unearned");
    el.innerHTML = '<span class="gem">' + (b.got
      ? '<svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6L9 17l-5-5"/></svg>'
      : '<svg width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0110 0v4"/></svg>'
    ) + '</span>' + b.name;
    row.appendChild(el);
  });

  document.getElementById("r-spoilers").innerHTML = TRACKS[state.track].spoilers;
  document.getElementById("r-switch").textContent =
    state.track === "tx" ? "Try the Contentious track →" : "Try the Transactions track →";

  go("results");
}

function restart() {
  state.scores = { s1: 0, s2: 0, s3: 0 };
  state.attempted = { s1: false, s2: false, s3: false };
  state.files = { s1: null };
  state.history = [];
  // Pre-fill the player form so the user doesn't re-type.
  document.getElementById("player-name").value  = state.player.name  || "";
  document.getElementById("player-email").value = state.player.email || "";
  document.getElementById("s1-paste").value = "";
  document.getElementById("s2-paste").value = "";
  document.getElementById("s1-filename").textContent = "no file selected";
  // Stage 3 textareas are rebuilt by loadStage3 when a track is picked.
  const wrap = document.getElementById("s3-grading-docs");
  if (wrap) wrap.innerHTML = "";
  ["s1", "s2", "s3"].forEach(s => {
    const fb = document.getElementById(s + "-fb");
    fb.classList.remove("show", "good", "warn", "bad");
    fb.innerHTML = "";
  });
  go("welcome", { silent: true });
}

function switchTrack() {
  const other = state.track === "tx" ? "co" : "tx";
  restart();
  setTimeout(() => pickTrack(other), 100);
}

// Document packs are downloaded as relative .zip files alongside this HTML.

go("welcome", { silent: true });
</script>
</body>
</html>
