<!doctype html>
<html lang="en">
<head>
<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>Legora · Bite-Size Warm-Up</title>
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml;utf8,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Cpath fill='%23005230' d='M16.8,0v15.2h15.2v1.6c-10.47.4-14.8,4.73-15.2,15.2h-1.6c-.4-10.47-4.73-14.8-15.2-15.2v-1.6C10.47,14.81,14.8,10.47,15.2,0h1.6Z'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Fraunces:opsz,wght@9..144,400;9..144,500;9..144,600&display=swap" rel="stylesheet">
<style>
  :root {
    /* Legora palette — deep forest green, warm cream, white cards */
    --bg:        #f5f3ee;     /* warm cream */
    --bg-alt:    #ece8de;     /* subtle band */
    --card:      #ffffff;
    --ink:       #0a1410;     /* near-black with green tint */
    --ink-2:     #1a2520;
    --muted:     #5a625e;
    --line:      #e3dfd5;     /* warm border */
    --line-2:    #efece4;
    --green:     #005230;     /* primary — Legora brand green */
    --green-2:   #00683d;     /* hover / mid */
    --green-3:   #1a7a4f;     /* lighter accent */
    --green-soft:#e6f0eb;     /* tint background */
    --green-tint:#cee0d4;
    --gold:      #b89859;
    --good:      #1a5a44;
    --warn:      #a8741a;
    --bad:       #a4302e;
    --radius:    14px;
    --radius-sm: 10px;
    --shadow-sm: 0 1px 0 rgba(10,20,16,0.04), 0 1px 2px rgba(10,20,16,0.05);
    --shadow-md: 0 1px 0 rgba(10,20,16,0.05), 0 10px 30px -8px rgba(15,61,46,0.12);
  }
  * { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; }
  body {
    background: var(--bg);
    color: var(--ink);
    font: 15px/1.6 "Inter", ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
    font-feature-settings: "ss01", "cv11";
    -webkit-font-smoothing: antialiased;
    min-height: 100vh;
  }
  .wrap { max-width: 900px; margin: 0 auto; padding: 36px 24px 96px; }

  /* ---- Header ---- */
  header.top {
    display: flex; align-items: center; justify-content: space-between;
    gap: 16px; margin-bottom: 28px;
  }
  .brand {
    display: flex; align-items: center; gap: 14px; font-weight: 500;
    color: var(--ink); letter-spacing: -0.01em;
  }
  .brand-wordmark {
    height: 22px; width: auto;
    display: inline-block;
  }
  .brand-wordmark svg { height: 100%; width: auto; display: block; }
  .brand-divider {
    width: 1px; height: 18px;
    background: var(--line);
  }
  .brand-text { font-size: 13.5px; color: var(--muted); font-weight: 500; letter-spacing: 0.01em; }

  .progress { display: flex; gap: 6px; align-items: center; }
  .progress .pip {
    width: 28px; height: 4px; border-radius: 2px;
    background: var(--line);
    transition: background 0.25s;
  }
  .progress .pip.active { background: var(--green); }
  .progress .pip.done   { background: var(--green-3); }

  /* ---- Card ---- */
  .card {
    background: var(--card);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    box-shadow: var(--shadow-md);
    padding: 36px 38px 30px;
    margin-bottom: 18px;
  }
  .card.tight { padding: 28px 32px 24px; }

  /* ---- Type ---- */
  h1 {
    font-family: "Fraunces", Georgia, serif;
    margin: 0 0 10px;
    font-size: 34px; line-height: 1.15;
    letter-spacing: -0.02em; font-weight: 500;
    color: var(--ink);
  }
  h2 {
    font-family: "Fraunces", Georgia, serif;
    margin: 0 0 6px;
    font-size: 26px; line-height: 1.2; letter-spacing: -0.015em;
    font-weight: 500;
  }
  h3 {
    margin: 22px 0 10px;
    font-size: 12px; font-weight: 600;
    color: var(--green-2);
    letter-spacing: 0.14em; text-transform: uppercase;
  }
  h3 .h3-sub {
    color: var(--muted); font-weight: 500;
    text-transform: none; letter-spacing: 0.01em;
    margin-left: 6px;
  }
  p { margin: 10px 0; color: var(--ink-2); }
  .muted { color: var(--muted); }
  .lead { font-size: 16.5px; color: var(--ink-2); }

  /* ---- Pills ---- */
  .pill {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 12px; border-radius: 999px;
    background: var(--green-soft); color: var(--green);
    border: 1px solid var(--green-tint);
    font-size: 12.5px; font-weight: 500;
    letter-spacing: 0.01em;
  }
  .pill.muted-pill { background: #fff; color: var(--muted); border-color: var(--line); }

  /* ---- Layout helpers ---- */
  .row  { display: flex; gap: 10px; flex-wrap: wrap; align-items: center; }
  .grid2 { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; margin-top: 18px; }
  @media (max-width: 720px) { .grid2 { grid-template-columns: 1fr; } }

  /* ---- Track tiles ---- */
  .tile {
    position: relative;
    background: #fff; border: 1px solid var(--line); border-radius: var(--radius);
    padding: 22px 22px 20px; cursor: pointer;
    transition: border-color 0.18s, transform 0.06s, box-shadow 0.18s;
  }
  .tile:hover {
    border-color: var(--green);
    box-shadow: 0 14px 30px -10px rgba(15,61,46,0.18);
    transform: translateY(-1px);
  }
  .tile-eyebrow { font-size: 11px; font-weight: 600; letter-spacing: 0.14em; text-transform: uppercase; color: var(--green-2); }
  .tile h3 {
    margin: 6px 0 6px; color: var(--ink);
    font-family: "Fraunces", Georgia, serif;
    font-size: 22px; font-weight: 500; letter-spacing: -0.01em;
    text-transform: none;
  }
  .tile .pitch { color: var(--muted); font-size: 14.5px; margin: 4px 0 12px; }
  .tile .tile-icon {
    position: absolute; top: 22px; right: 22px;
    width: 36px; height: 36px; border-radius: 50%;
    background: var(--green-soft);
    display: flex; align-items: center; justify-content: center;
    color: var(--green);
  }

  /* ---- Buttons ---- */
  .btn {
    appearance: none; border: 0; cursor: pointer;
    background: var(--green); color: #fff;
    font-family: inherit; font-weight: 500; font-size: 14.5px;
    padding: 11px 22px; border-radius: 999px;
    transition: background 0.15s, transform 0.06s;
    letter-spacing: 0.005em;
  }
  .btn:hover { background: var(--ink); }
  .btn:active { transform: translateY(1px); }
  .btn.ghost {
    background: transparent; color: var(--ink); border: 1px solid var(--line);
  }
  .btn.ghost:hover { border-color: var(--green); color: var(--green); background: #fff; }
  .btn.small { padding: 8px 14px; font-size: 13px; }

  /* ---- Hint block (Legora-style sage panel) ---- */
  .hint {
    background: var(--green-soft);
    border: 1px solid var(--green-tint);
    border-radius: var(--radius-sm);
    padding: 16px 18px;
    margin: 14px 0;
    color: var(--ink-2);
  }
  .hint .tag {
    display: inline-flex; align-items: center; gap: 6px;
    font-size: 11px; letter-spacing: 0.14em; text-transform: uppercase;
    color: var(--green-2); margin-bottom: 8px; font-weight: 600;
  }
  .hint ul { margin: 6px 0 0; padding-left: 22px; }
  .hint li { margin: 6px 0; }
  .hint code, .hint em { font-style: italic; color: var(--ink); }
  .hint code { font-family: "Fraunces", Georgia, serif; font-style: normal; }

  /* ---- Doc list ---- */
  .doclist { margin: 8px 0 0; padding: 0; list-style: none; }
  .doclist li {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 12px; background: #fff; border: 1px solid var(--line);
    border-radius: var(--radius-sm); margin-bottom: 6px;
    font-family: ui-monospace, SFMono-Regular, "JetBrains Mono", Menlo, monospace;
    font-size: 12.5px; color: var(--ink-2);
  }
  .doclist li .doc-ico {
    flex: 0 0 16px; color: var(--green); opacity: 0.75;
  }

  /* ---- Inputs ---- */
  textarea, input[type=text] {
    width: 100%; background: #fff; color: var(--ink);
    border: 1px solid var(--line); border-radius: var(--radius-sm);
    padding: 12px 14px; font-size: 14.5px;
    font-family: inherit; resize: vertical;
    transition: border-color 0.15s, box-shadow 0.15s;
  }
  textarea { min-height: 120px; }
  textarea:focus, input[type=text]:focus {
    outline: none; border-color: var(--green);
    box-shadow: 0 0 0 3px rgba(15,61,46,0.10);
  }
  textarea::placeholder { color: var(--muted); opacity: 0.7; }

  .file-input { display: flex; align-items: center; gap: 12px; flex-wrap: wrap; }
  .file-input label.btn { cursor: pointer; }
  .file-input input { display: none; }
  .file-input .file-name {
    color: var(--muted); font-family: ui-monospace, monospace; font-size: 13px;
  }

  /* ---- Actions ---- */
  .actions {
    display: flex; gap: 10px; flex-wrap: wrap; margin-top: 22px;
    justify-content: flex-end; align-items: center;
  }
  .actions .left { margin-right: auto; }

  /* ---- Feedback ---- */
  .feedback {
    margin-top: 16px; padding: 12px 14px; border-radius: var(--radius-sm);
    border: 1px solid var(--line); background: #fff;
    display: none;
    font-size: 14px; line-height: 1.55;
  }
  .feedback.show { display: block; }
  .feedback.good { border-color: var(--green-tint); background: var(--green-soft); color: var(--ink); }
  .feedback.warn { border-color: #e9d8b2; background: #faf3e3; color: var(--ink); }
  .feedback.bad  { border-color: #f0c9c7; background: #fbe9e8; color: var(--ink); }
  .feedback em { color: var(--green-2); font-style: italic; }

  /* ---- Stage head ---- */
  .stage-head {
    display: flex; align-items: baseline; justify-content: space-between;
    gap: 16px; margin-bottom: 14px;
  }
  .stage-head .label {
    color: var(--green-2); font-size: 11px;
    letter-spacing: 0.18em; text-transform: uppercase; font-weight: 600;
  }

  /* ---- Badge ---- */
  .badge {
    display: inline-flex; align-items: center; gap: 8px;
    background: var(--green-soft); color: var(--green);
    border: 1px solid var(--green-tint); border-radius: 999px;
    padding: 6px 14px; font-weight: 500; font-size: 13px;
  }
  .badge.muted-b {
    background: #fff; color: var(--muted); border-color: var(--line);
  }
  .badge .ico { width: 14px; height: 14px; }

  /* ---- Results ---- */
  .result-headline { text-align: center; padding: 8px 0 0; }
  .result-headline .score {
    font-family: "Fraunces", Georgia, serif;
    font-size: 68px; font-weight: 500; letter-spacing: -0.04em;
    color: var(--green); line-height: 1;
  }
  .result-headline .out-of {
    color: var(--muted); font-size: 22px; font-family: "Fraunces", Georgia, serif;
    font-weight: 400;
  }
  .result-headline .tier {
    margin-top: 8px; font-size: 14px; color: var(--muted);
    letter-spacing: 0.08em; text-transform: uppercase; font-weight: 500;
  }
  .badges-row {
    display: flex; flex-wrap: wrap; gap: 10px; justify-content: center;
    margin: 22px 0 8px;
  }
  .achievement {
    display: inline-flex; align-items: center; gap: 8px;
    background: #fff; border: 1px solid var(--line);
    border-radius: 999px; padding: 8px 16px;
    font-size: 13.5px; font-weight: 500; color: var(--ink);
    transition: all 0.2s;
  }
  .achievement .gem {
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--green); color: #fff;
    display: inline-flex; align-items: center; justify-content: center;
  }
  .achievement.unearned {
    color: var(--muted); border-style: dashed; background: transparent;
  }
  .achievement.unearned .gem { background: var(--line); color: var(--muted); }

  /* ---- Misc ---- */
  .footer-note {
    text-align: center; color: var(--muted); font-size: 12.5px; margin-top: 24px;
    letter-spacing: 0.005em;
  }
  details {
    background: #fff; border: 1px solid var(--line);
    border-radius: var(--radius-sm); padding: 12px 16px;
    margin: 12px 0;
  }
  details summary {
    cursor: pointer; color: var(--green-2); font-weight: 500; font-size: 14px;
    list-style: none;
  }
  details summary::-webkit-details-marker { display: none; }
  details summary::before {
    content: "+"; display: inline-block; width: 18px; color: var(--green);
    font-family: "Fraunces", serif; font-weight: 600;
  }
  details[open] summary::before { content: "−"; }
  details p { margin: 8px 0; font-size: 14px; }
  details code {
    background: var(--green-soft); color: var(--green);
    padding: 1px 6px; border-radius: 4px; font-size: 12.5px;
  }
  .hide { display: none !important; }

  /* Stat row on welcome */
  .stat-row {
    display: flex; gap: 12px; margin-top: 20px; flex-wrap: wrap;
  }

  /* "How this works" list on welcome */
  .how-list {
    list-style: none; margin: 8px 0 18px; padding: 0;
  }
  .how-list li {
    display: flex; align-items: flex-start; gap: 16px;
    padding: 14px 0;
    border-bottom: 1px solid var(--line-2);
  }
  .how-list li:last-child { border-bottom: 0; }
  .how-list .num {
    flex: 0 0 32px;
    width: 32px; height: 32px; border-radius: 50%;
    display: inline-flex; align-items: center; justify-content: center;
    background: var(--green-soft); color: var(--green);
    font-family: "Fraunces", Georgia, serif;
    font-size: 16px; font-weight: 600;
    border: 1px solid var(--green-tint);
  }
  .how-list .num.bonus {
    background: var(--green); color: #fff; border-color: var(--green);
    font-size: 13px;
  }
  .how-list > li > div {
    flex: 1; color: var(--ink-2); font-size: 15px; line-height: 1.55;
  }
  .how-list strong { color: var(--ink); font-weight: 600; }
  .how-list .how-mins {
    display: inline-block; margin-left: 8px;
    color: var(--muted); font-size: 12.5px;
    letter-spacing: 0.02em;
  }
  .setup-note {
    margin-top: 6px; padding: 12px 14px;
    background: var(--bg-alt); border-radius: var(--radius-sm);
    color: var(--muted); font-size: 14px;
  }
  .lg-link {
    color: var(--green); font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid var(--green-tint);
    padding-bottom: 1px;
    transition: border-color 0.15s, color 0.15s;
  }
  .lg-link:hover { color: var(--ink); border-bottom-color: var(--green); }
  .track-footnote {
    margin-top: 18px; padding-top: 16px;
    border-top: 1px solid var(--line-2);
    font-size: 13.5px; text-align: center;
  }

  /* Stage 3 — named-doc rows, one requirement each */
  .doc-row {
    margin-bottom: 18px;
    border: 1px solid var(--line);
    border-radius: var(--radius-sm);
    background: #fff;
    overflow: hidden;
  }
  .doc-row .doc-label {
    display: flex; align-items: center; gap: 10px;
    padding: 10px 14px;
    background: var(--green-soft);
    border-bottom: 1px solid var(--green-tint);
    color: var(--ink);
  }
  .doc-row .doc-label .doc-ico { color: var(--green); opacity: 0.85; flex: 0 0 14px; }
  .doc-row .doc-name {
    font-family: ui-monospace, SFMono-Regular, "JetBrains Mono", Menlo, monospace;
    font-size: 12.5px;
  }
  .doc-row .doc-field {
    padding: 14px 16px 16px;
  }
  .doc-row .doc-ask {
    margin-bottom: 8px;
  }
  .doc-row .doc-ask-col {
    display: block;
    font-size: 11.5px; font-weight: 700;
    color: var(--green);
    letter-spacing: 0.16em; text-transform: uppercase;
    margin-bottom: 3px;
  }
  .doc-row .doc-ask-prompt {
    display: block;
    color: var(--ink-2); font-size: 14.5px;
    font-weight: 500;
  }
  .doc-row .doc-input {
    border-radius: var(--radius-sm);
    font-size: 14.5px; padding: 11px 14px;
    width: 100%; background: #fff; color: var(--ink);
    border: 1px solid var(--line);
    font-family: inherit;
  }
  .doc-row .doc-input:focus {
    outline: none; border-color: var(--green);
    box-shadow: 0 0 0 3px rgba(0,82,48,0.10);
  }

  /* Soft-block feedback actions */
  .feedback-actions {
    display: flex; gap: 10px; flex-wrap: wrap;
    justify-content: flex-end; margin-top: 14px;
    padding-top: 12px; border-top: 1px solid var(--line);
  }

  /* Platform tips card on results */
  .tips-card {
    margin-top: 20px; padding: 22px 24px;
    background: var(--green-soft);
    border: 1px solid var(--green-tint);
    border-radius: var(--radius);
  }
  .tips-card .tips-head {
    display: flex; align-items: center; gap: 10px;
    color: var(--green); font-weight: 600; font-size: 13px;
    text-transform: uppercase; letter-spacing: 0.14em;
    margin-bottom: 12px;
  }
  .tips-card ul {
    margin: 0; padding-left: 22px;
  }
  .tips-card li {
    margin-bottom: 10px; font-size: 14.5px; line-height: 1.55; color: var(--ink-2);
  }
  .tips-card li:last-child { margin-bottom: 0; }
  .tips-card strong { color: var(--ink); font-weight: 600; }
  .tips-card em { color: var(--green-2); font-style: italic; }

  /* Welcome — player form */
  .player-form {
    display: grid; grid-template-columns: 1fr 1fr; gap: 12px;
    margin-top: 6px;
  }
  @media (max-width: 560px) { .player-form { grid-template-columns: 1fr; } }
  .player-form .field {
    display: flex; flex-direction: column; gap: 6px;
  }
  .player-form label {
    font-size: 12px; font-weight: 600;
    color: var(--green-2);
    letter-spacing: 0.06em; text-transform: uppercase;
  }
  .player-form label .optional {
    color: var(--muted); font-weight: 500;
    text-transform: none; letter-spacing: 0.01em;
  }
  .player-form input.invalid {
    border-color: #e0a4a3 !important;
    box-shadow: 0 0 0 3px rgba(164,48,46,0.10) !important;
  }
  .player-note {
    margin-top: 8px; font-size: 13px;
  }
  .form-error {
    margin-top: 12px; padding: 10px 14px;
    background: #fbe9e8; border: 1px solid #f0c9c7;
    border-radius: var(--radius-sm); color: var(--bad);
    font-size: 13.5px; display: none;
  }
  .form-error.show { display: block; }

  /* Back button — always left of the actions row */
  .actions .back-btn {
    margin-right: auto;
    background: transparent; color: var(--muted);
    border: 1px solid transparent;
    padding: 8px 12px; border-radius: 999px;
    font-size: 13px; cursor: pointer; font-family: inherit;
  }
  .actions .back-btn:hover { color: var(--green); }
</style>
</head>
<body>
<div class="wrap" id="app">

  <header class="top">
    <div class="brand">
