  if (el.files && el.files.length) {
    state.files[stage] = el.files[0].name;
    nameEl.textContent = el.files[0].name;
  } else {
    state.files[stage] = null;
    nameEl.textContent = "no file selected";
  }
}

function normalize(s) {
  return (s || "").toLowerCase()
    .replace(/[‘’“”'`""]/g, "")
    .replace(/[^\w\s.,;:£€$%\-()]/g, " ")
    .replace(/\s+/g, " ")
    .trim();
}

// ---------- Soft-block on warn/bad feedback ----------
function actionRow(stage) {
  return '<div class="feedback-actions">' +
    '<button type="button" class="btn ghost small" onclick="dismissFeedback(\'' + stage + '\')">Hand it in again</button>' +
    '<button type="button" class="btn small" onclick="confirmAdvance(\'' + stage + '\')">I\'m sure — submit anyway →</button>' +
  '</div>';
}
function dismissFeedback(stage) {
  const fb = document.getElementById(stage + "-fb");
  if (!fb) return;
  fb.classList.remove("show", "good", "warn", "bad");
  fb.innerHTML = "";
  // Scroll the answer area back into view so the player can edit.
  const focusEl =
    stage === "s1" ? document.getElementById("s1-paste") :
    stage === "s2" ? document.getElementById("s2-paste") :
    document.querySelector("#s3-grading-docs textarea");
  if (focusEl) focusEl.focus({ preventScroll: false });
}
function confirmAdvance(stage) {
  if (stage === "s1") go("s2");
  else if (stage === "s2") go("s3-gate");
  else if (stage === "s3") showResults();
}

function checkS1() {
  state.attempted.s1 = true;
  const c = TRACKS[state.track].s1;
  const paste = document.getElementById("s1-paste").value;
  const file = state.files.s1;
  const fb = document.getElementById("s1-fb");
  fb.classList.remove("good", "warn", "bad");

  let hits = 0;
  const norm = normalize(paste);
  if (norm.length > 0) {
    const seen = new Set();
    c.keywords.forEach(k => {
      const n = normalize(k);
      if (norm.includes(n)) seen.add(n);
    });
    hits = seen.size;
  }

  let score = 0; let mood = "warn"; let msg = "";
  if (paste.trim().length < 20 && !file) {
    score = 0; mood = "bad";
    msg = "We need <em>something</em>. Either paste your bullets or upload the file. Try again — Assistant doesn't bite.";
  } else if (hits >= 2 || file) {
    // Generous: any 2 relevant angles = full marks. A Word/PDF upload also counts.
    score = 1; mood = "good";
    msg = "Solid brief. " + (hits >= 2
        ? `We spotted ${hits} of the angles a partner would want flagged. Any decent Assistant brief on this matter would cover several of: ${state.track === "tx" ? "deal value, CMA risk, the earn-out mechanics, the November indemnity, the unusual MAC/non-poach drafting, and the side letter" : "the complaint and the denial, the loss adjuster's view, the SLA breach, FOS exposure, settlement strategy, and the wider 28-case pattern"}. You got there.`
        : `Counted in good faith — you've handed in the file, that does the job.`);
  } else if (hits >= 1) {
    score = 0.5; mood = "warn";
    msg = `Half marks. We only spotted one of the angles a partner would want — a brief usually covers 4–6. Try a re-prompt — ask Assistant for "<em>punchy bullets covering value, conditions, unusual terms, risks</em>". Or accept the half and press on.`;
  } else {
    score = 0; mood = "bad";
    msg = "We couldn't spot the usual partner-call signals. Try asking Assistant for talking points (5–7 bullets) rather than a summary — and make sure all three docs are attached.";
  }

  state.scores.s1 = score;
  fb.classList.add(mood, "show");
  if (mood === "good") {
    fb.innerHTML = msg;
    setTimeout(() => go("s2"), 900);
  } else {
    fb.innerHTML = msg + actionRow("s1");
  }
}

function checkS2() {
  state.attempted.s2 = true;
  const c = TRACKS[state.track].s2;
  const paste = document.getElementById("s2-paste").value;
  const fb = document.getElementById("s2-fb");
  fb.classList.remove("good", "warn", "bad");

  const norm = normalize(paste);
  let hits = 0;
  c.requiredPhrases.forEach(p => { if (norm.includes(normalize(p))) hits++; });

  let score = 0; let mood = "warn"; let msg = "";
  if (paste.trim().length < 30) {
    score = 0; mood = "bad";
    msg = "That doesn't look like a verbatim clause — too short. Database Search will hand you the wording; copy the whole sentence.";
  } else if (hits >= c.minRequired) {
    score = 1; mood = "good";
    msg = `Got it. You found ${hits} of the ${c.requiredPhrases.length} distinctive markers in the clause — that's the one.`;
  } else if (hits >= 1) {
    score = 0.5; mood = "warn";
    msg = `Close, but only ${hits} of the ${c.requiredPhrases.length} distinctive phrases match. Re-check Database Search — there's a specific document where this lives.`;
  } else {
    score = 0; mood = "bad";
    msg = "Not the clause we're after. Hint: search for the <em>idea</em>, not exact words — Database Search is semantic.";
  }

  state.scores.s2 = score;
  fb.classList.add(mood, "show");
  if (mood === "good") {
    fb.innerHTML = msg;
    setTimeout(() => go("s3-gate"), 1000);
  } else {
    fb.innerHTML = msg + actionRow("s2");
  }
}

function checkS3() {
  state.attempted.s3 = true;
  const c = TRACKS[state.track].s3;
  const fb = document.getElementById("s3-fb");
  fb.classList.remove("good", "warn", "bad");

  // Each of the 3 docs has one required column. Count how many had a plausible answer.
  let correct = 0;
  let attempted = 0;
  c.gradingDocs.forEach((gd, i) => {
    const v = document.getElementById("s3-doc-" + i).value;
    const norm = normalize(v);
    const looksFilled = v.trim().length >= 2;
    if (looksFilled) attempted++;
    const matched = looksFilled && gd.hits.some(h => norm.includes(normalize(h)));
    if (matched) correct++;
  });

  let score = 0; let mood = "warn"; let msg = "";
  if (attempted === 0) {
    score = 0; mood = "bad";
    msg = "Nothing filled in. Run the Tabular Review, then come back and read off the three values.";
  } else if (correct === 3) {
    score = 1; mood = "good";
    msg = "All three landed. That's a Tabular Review you'd hand to a partner without flinching.";
  } else if (correct === 2) {
    score = 0.66; mood = "warn";
    msg = `Two of three matched. The third value doesn't line up with what the grid would give — worth a sanity-check.`;
  } else if (correct === 1) {
    score = 0.33; mood = "warn";
    msg = `Only one of the three matched. Re-open the Tabular Review and double-check the values against the document we asked about.`;
  } else {
    score = 0; mood = "bad";
    msg = `${attempted} filled in but none matched. Make sure you're reading the value from the right column of the right document.`;
  }

  state.scores.s3 = score;
  fb.classList.add(mood, "show");
  if (mood === "good") {
    fb.innerHTML = msg;
    setTimeout(() => showResults(), 1000);
  } else {
    fb.innerHTML = msg + actionRow("s3");
  }
}

